# Copy this file to the repo root as .env and adjust paths for your machine.
# .env is gitignored; never commit real local paths or secrets.

VAULT="$HOME/ObsidianVaults/second-brain"
FINANCE_DIR="$VAULT/91_finance"
STATEMENTS_DIR="$FINANCE_DIR/Statements"
ACCOUNTS_DIR="$FINANCE_DIR/Accounts"
REVIEWS_DIR="$FINANCE_DIR/Reviews"

# Absolute path to the markitdown binary used for PDF -> Markdown conversion.
MARKITDOWN_BIN="$HOME/.venv/bin/markitdown"
