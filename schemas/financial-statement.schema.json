{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jlgarcia75/financial-advisor/schema/financial-statement.schema.json",
  "title": "Financial Statement",
  "type": "object",
  "required": [
    "statement_id",
    "source",
    "institution",
    "account",
    "statement_period",
    "currency"
  ],
  "properties": {
    "statement_id": {
      "type": "string",
      "description": "Stable ID derived from filename, e.g. 2026-06_chase-sapphire-1234_statement"
    },
    "source": {
      "type": "string",
      "enum": ["manual_statement"]
    },
    "source_file": {
      "type": "string"
    },
    "institution": {
      "type": "string"
    },
    "account": {
      "type": "string"
    },
    "account_last4": {
      "type": "string",
      "pattern": "^[0-9]{4}$"
    },
    "account_type": {
      "type": "string",
      "enum": [
        "checking",
        "savings",
        "credit_card",
        "brokerage",
        "retirement",
        "hsa",
        "loan",
        "mortgage",
        "unknown"
      ]
    },
    "statement_period": {
      "type": "object",
      "required": ["period"],
      "properties": {
        "period": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$"
        },
        "start_date": {
          "type": "string",
          "format": "date"
        },
        "end_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "balances": {
      "type": "object",
      "properties": {
        "opening_balance": { "type": "number" },
        "closing_balance": { "type": "number" },
        "available_balance": { "type": "number" },
        "statement_balance": { "type": "number" },
        "minimum_payment": { "type": "number" },
        "payment_due_date": { "type": "string", "format": "date" }
      }
    },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "description", "amount"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "posted_date": { "type": "string", "format": "date" },
          "description": { "type": "string" },
          "merchant": { "type": "string" },
          "amount": { "type": "number" },
          "type": {
            "type": "string",
            "enum": ["debit", "credit", "fee", "interest", "payment", "transfer", "unknown"]
          },
          "category": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "holdings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string" },
          "ticker": { "type": "string" },
          "quantity": { "type": "number" },
          "price": { "type": "number" },
          "value": { "type": "number" },
          "cost_basis": { "type": "number" },
          "asset_type": {
            "type": "string",
            "enum": ["cash", "stock", "etf", "mutual_fund", "bond", "crypto", "option", "other"]
          }
        }
      }
    },
    "extraction": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "extracted_at": { "type": "string", "format": "date-time" },
        "review_status": {
          "type": "string",
          "enum": ["needs_review", "ready", "rejected", "conversion_issue"]
        },
        "notes": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}