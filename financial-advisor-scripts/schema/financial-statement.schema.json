{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jlgarcia75/financial-advisor/schema/financial-statement.schema.json",
  "title": "Financial Statement",
  "type": "object",
  "required": [
    "statement_id",
    "source",
    "institution",
    "account",
    "account_last4",
    "account_type",
    "statement_period",
    "currency",
    "extraction"
  ],
  "properties": {
    "statement_id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "manual_statement"
      ]
    },
    "source_file": {
      "type": "string"
    },
    "institution": {
      "type": "string"
    },
    "account": {
      "type": "string"
    },
    "account_last4": {
      "type": "string",
      "pattern": "^[0-9]{4}$"
    },
    "account_type": {
      "type": "string",
      "enum": [
        "checking",
        "savings",
        "credit_card",
        "brokerage",
        "retirement",
        "hsa",
        "loan",
        "mortgage",
        "unknown"
      ]
    },
    "statement_period": {
      "type": "object",
      "required": [
        "period"
      ],
      "properties": {
        "period": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$"
        },
        "start_date": {
          "type": "string",
          "format": "date"
        },
        "end_date": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "balances": {
      "type": "object",
      "properties": {
        "opening_balance": {
          "type": "number"
        },
        "closing_balance": {
          "type": "number"
        },
        "available_balance": {
          "type": "number"
        },
        "statement_balance": {
          "type": "number"
        },
        "minimum_payment": {
          "type": "number"
        },
        "payment_due_date": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "description",
          "amount"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "posted_date": {
            "type": "string",
            "format": "date"
          },
          "description": {
            "type": "string"
          },
          "merchant": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "debit",
              "credit",
              "fee",
              "interest",
              "payment",
              "transfer",
              "unknown"
            ]
          },
          "category": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "holdings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "value"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ticker": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "price": {
            "type": "number"
          },
          "value": {
            "type": "number"
          },
          "cost_basis": {
            "type": "number"
          },
          "asset_type": {
            "type": "string",
            "enum": [
              "cash",
              "stock",
              "etf",
              "mutual_fund",
              "bond",
              "crypto",
              "option",
              "other"
            ]
          },
          "price_paid": {
            "type": [
              "number",
              "null"
            ]
          },
          "date_acquired": {
            "type": "string"
          },
          "date_sold": {
            "type": "string"
          },
          "proceeds": {
            "type": [
              "number",
              "null"
            ]
          },
          "realized_gain_loss": {
            "type": [
              "number",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "extraction": {
      "type": "object",
      "required": [
        "tool",
        "extracted_at",
        "review_status"
      ],
      "properties": {
        "tool": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "needs_review",
            "ready",
            "rejected",
            "conversion_issue"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "brokerage_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "activity_type": {
            "type": "string",
            "enum": [
              "holding",
              "sale",
              "buy",
              "income",
              "unknown"
            ]
          },
          "symbol": {
            "type": "string"
          },
          "security_name": {
            "type": "string"
          },
          "shares": {
            "type": [
              "number",
              "null"
            ]
          },
          "price_paid": {
            "type": [
              "number",
              "null"
            ]
          },
          "current_price": {
            "type": [
              "number",
              "null"
            ]
          },
          "cost_basis": {
            "type": [
              "number",
              "null"
            ]
          },
          "market_value": {
            "type": [
              "number",
              "null"
            ]
          },
          "proceeds": {
            "type": [
              "number",
              "null"
            ]
          },
          "realized_gain_loss": {
            "type": [
              "number",
              "null"
            ]
          },
          "date_acquired": {
            "type": "string"
          },
          "date_sold": {
            "type": "string"
          },
          "raw_line": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
